# ─────────────────────────────────────────────
#  DEFINICIÓN DEL LENGUAJE "LexC"
#  (puedes personalizar todo esto)
# ─────────────────────────────────────────────

# Palabras reservadas estándar
KEYWORDS = {
    "si", "sino", "para", "mientras", "retorna",
    "verdadero", "falso", "nulo",
    # Tres palabras reservadas propias:
    "mostrar",   # equivalente a print
    "captura",   # equivalente a input
    "rompe",     # equivalente a break
}

# Tipos de datos
DATA_TYPES = {"entero", "decimal", "cadena", "booleano"}

# Tabla de tokens: (nombre_token, patron_regex)
TOKEN_RULES = [
    ("COMENTARIO",      r"//[^\n]*"),
    ("CADENA_LIT",      r'"[^"\n]*"'),
    ("DECIMAL",         r"\d+\.\d+"),
    ("ENTERO",          r"\d+"),
    ("IGUAL_IGUAL",     r"=="),
    ("DISTINTO",        r"!="),
    ("MAYOR_IGUAL",     r">="),
    ("MENOR_IGUAL",     r"<="),
    ("AND",             r"&&"),
    ("OR",              r"\|\|"),
    ("ASIGNACION",      r"="),
    ("MAYOR",           r">"),
    ("MENOR",           r"<"),
    ("MAS",             r"\+"),
    ("MENOS",           r"-"),
    ("MULT",            r"\*"),
    ("DIV",             r"/"),
    ("MODULO",          r"%"),
    ("FIN_LINEA",       r";"),
    ("PAREN_ABRE",      r"\("),
    ("PAREN_CIERRA",    r"\)"),
    ("LLAVE_ABRE",      r"\{"),
    ("LLAVE_CIERRA",    r"\}"),
    ("CORCH_ABRE",      r"\["),
    ("CORCH_CIERRA",    r"\]"),
    ("COMA",            r","),
    ("PUNTO",           r"\."),
    ("HASH",            r"#"),
    ("AMPERSAND",       r"&"),
    ("INTERROG",        r"\?"),
    ("EXCLAMACION",     r"!"),
    ("ARROBA",          r"@"),
    ("IDENTIFICADOR",   r"[a-zA-Z_áéíóúÁÉÍÓÚñÑ][a-zA-Z0-9_áéíóúÁÉÍÓÚñÑ]*"),
    ("ESPACIO",         r"[ \t\r]+"),
    ("NUEVA_LINEA",     r"\n"),
    ("DESCONOCIDO",     r"."),
]

MASTER_PATTERN = re.compile(
    "|".join(f"(?P<{name}>{pattern})" for name, pattern in TOKEN_RULES)
)

# ─────────────────────────────────────────────
#  ANALIZADOR LÉXICO
# ─────────────────────────────────────────────
def analizar_lexico(codigo: str):
    tokens = []
    errores = []
    linea = 1

    for mo in MASTER_PATTERN.finditer(codigo):
        tipo = mo.lastgroup
        valor = mo.group()

        if tipo == "NUEVA_LINEA":
            linea += 1
            continue
        if tipo == "ESPACIO":
            continue
        if tipo == "DESCONOCIDO":
            errores.append({
                "linea": linea,
                "lexema": valor,
                "mensaje": f"Carácter no reconocido: '{valor}'"
            })
            continue

        # Clasificar identificadores
        if tipo == "IDENTIFICADOR":
            if valor in KEYWORDS:
                tipo = "PALABRA_RESERVADA"
            elif valor in DATA_TYPES:
                tipo = "TIPO_DATO"

        tokens.append({
            "token": tipo,
            "lexema": valor,
            "linea": linea
        })

    return tokens, errores

