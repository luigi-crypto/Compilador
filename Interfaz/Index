    # ── Helpers de widgets ───────────────────
    def _flat_button(self, parent, text, cmd, bg, fg, pad=(0, 0)):
        btn = tk.Button(
            parent, text=text, command=cmd,
            bg=bg, fg=fg, font=FONT_BTN,
            relief="flat", cursor="hand2",
            padx=pad[0], pady=pad[1],
            activebackground=BTN_HOVER, activeforeground="white",
            bd=0
        )
        return btn

    def _analyzer_button(self, parent, title, subtitle, cmd,
                         color, disabled=False):
        container = tk.Frame(parent, bg=color, cursor="hand2" if not disabled else "arrow")
        container.columnconfigure(0, weight=1)

        inner = tk.Frame(container, bg=color, padx=14, pady=12)
        inner.grid(row=0, column=0, sticky="ew")

        fg_title = TEXT_MAIN if not disabled else "#3A5A6A"
        fg_sub   = "#A0C0D0" if not disabled else "#2A3A4A"

        lbl_title = tk.Label(inner, text=title, bg=color,
                             fg=fg_title, font=FONT_BTN, anchor="w")
        lbl_title.grid(row=0, column=0, sticky="w")

        lbl_sub = tk.Label(inner, text=subtitle, bg=color,
                           fg=fg_sub, font=FONT_LABEL, anchor="w")
        lbl_sub.grid(row=1, column=0, sticky="w")

        if not disabled and cmd:
            for w in (container, inner, lbl_title, lbl_sub):
                w.bind("<Button-1>", lambda e: cmd())
                w.bind("<Enter>", lambda e, c=color: self._btn_enter(e, c))
                w.bind("<Leave>", lambda e, c=color: self._btn_leave(e, c))

        return container

    def _btn_enter(self, event, base_color):
        w = event.widget
        try:
            # Aclarar ligeramente
            r, g, b = self.winfo_rgb(base_color)
            r = min(65535, r + 8000)
            g = min(65535, g + 8000)
            b = min(65535, b + 8000)
            lighter = f"#{r//256:02x}{g//256:02x}{b//256:02x}"
            w.configure(bg=lighter)
        except Exception:
            pass

    def _btn_leave(self, event, base_color):
        event.widget.configure(bg=base_color)

    def _style_treeview(self):
        style = ttk.Style()
        style.configure("Dark.Treeview",
                        background=BG_RESULTS,
                        foreground=TEXT_MAIN,
                        fieldbackground=BG_RESULTS,
                        rowheight=26,
                        font=FONT_MONO_SM)
        style.configure("Dark.Treeview.Heading",
                        background="#1E3A5A",
                        foreground=ACCENT_GREEN,
                        font=("Segoe UI", 9, "bold"))
        style.map("Dark.Treeview",
                  background=[("selected", ACCENT_BLUE)],
                  foreground=[("selected", "white")])

    # ── Números de línea ─────────────────────
    def _update_line_numbers(self):
        self.line_numbers.config(state="normal")
        self.line_numbers.delete("1.0", "end")
        lines = int(self.editor.index("end-1c").split(".")[0])
        nums = "\n".join(str(i) for i in range(1, lines + 1))
        self.line_numbers.insert("1.0", nums)
        self.line_numbers.config(state="disabled")

    def _editor_scroll_y(self, *args):
        self.editor.yview(*args)
        self.line_numbers.yview(*args)

    def _sync_scroll(self, event):
        self.line_numbers.yview_scroll(int(-1 * (event.delta / 120)), "units")

    def _on_editor_change(self, event=None):
        self._update_line_numbers()
        if self._placeholder_active():
            pass

    # ── Placeholder ──────────────────────────
    def _set_placeholder(self):
        placeholder = (
            "// Escribe o pega tu código aquí...\n"
            "// También puedes cargar un archivo de texto con el botón 📂\n\n"
            "entero x = 10;\n"
            "entero y = 20;\n\n"
            "si (x < y) {\n"
            "    mostrar(\"x es menor\");\n"
            "} sino {\n"
            "    mostrar(\"y es menor\");\n"
            "}"
        )
        self.editor.insert("1.0", placeholder)
        self.editor.tag_add("placeholder", "1.0", "end")
        self.editor.tag_config("placeholder", foreground="#2A5A4A")
        self.editor.bind("<FocusIn>", self._clear_placeholder)

    def _placeholder_active(self):
        return "placeholder" in self.editor.tag_names("1.0")

    def _clear_placeholder(self, event=None):
        if self._placeholder_active():
            self.editor.delete("1.0", "end")
            self.editor.tag_delete("placeholder")
            self.editor.unbind("<FocusIn>")

    # ── Acciones ─────────────────────────────
    def _cargar_archivo(self):
        path = filedialog.askopenfilename(
            title="Cargar archivo de código",
            filetypes=[
                ("Archivos de texto", "*.txt *.lc *.lexc *.code"),
                ("Todos los archivos", "*.*")
            ]
        )
        if not path:
            return
        try:
            contenido = None
            for enc in ("utf-8-sig", "utf-8", "latin-1", "cp1252"):
                try:
                    with open(path, "r", encoding=enc) as f:
                        contenido = f.read()
                    break
                except (UnicodeDecodeError, LookupError):
                    continue
            if contenido is None:
                raise ValueError("No se pudo detectar la codificación del archivo.")
            self.editor.delete("1.0", "end")
            if self._placeholder_active():
                self.editor.tag_delete("placeholder")
                self.editor.unbind("<FocusIn>")
            self.editor.insert("1.0", contenido)
            self._update_line_numbers()
            self.status_lbl.config(
                text=f"Archivo cargado: {path.split('/')[-1]}",
                fg=SUCCESS_COLOR
            )
        except Exception as e:
            messagebox.showerror("Error", f"No se pudo leer el archivo:\n{e}")

    def _limpiar_editor(self):
        self.editor.delete("1.0", "end")
        self._limpiar_resultados()
        self._set_placeholder()
        self._update_line_numbers()
        self.status_lbl.config(text="", fg=TEXT_DIM)

    def _limpiar_resultados(self):
        for item in self.tree.get_children():
            self.tree.delete(item)
        self.errores_text.config(state="normal")
        self.errores_text.delete("1.0", "end")
        self.errores_text.config(state="disabled")

    def _run_lexico(self):
        codigo = self.editor.get("1.0", "end-1c")
        if not codigo.strip() or self._placeholder_active():
            messagebox.showwarning("Sin código",
                                   "Escribe o carga código antes de analizar.")
            return

        self._limpiar_resultados()
        tokens, errores = analizar_lexico(codigo)

        # Llenar tabla de tokens
        tag_colors = {
            "PALABRA_RESERVADA": "#7DC72B",
            "TIPO_DATO":         "#4ECDC4",
            "CADENA_LIT":        "#E8A87C",
            "ENTERO":            "#96CEB4",
            "DECIMAL":           "#96CEB4",
            "COMENTARIO":        "#5A7A5A",
        }

        for i, tok in enumerate(tokens, 1):
            tag = tok["token"]
            iid = self.tree.insert(
                "", "end",
                values=(i, tok["token"], tok["lexema"], tok["linea"]),
                tags=(tag,)
            )
            color = tag_colors.get(tag, TEXT_MAIN)
            self.tree.tag_configure(tag, foreground=color)

        # Llenar errores
        self.errores_text.config(state="normal")
        if errores:
            for err in errores:
                self.errores_text.insert(
                    "end",
                    f"  ❌  Línea {err['linea']:>3}  |  {err['mensaje']}\n\n"
                )
            self.nb.tab(1, text=f"  Errores ({len(errores)})  ")
        else:
            self.errores_text.insert(
                "end",
                "  ✅  No se encontraron errores léxicos.\n"
            )
            self.errores_text.tag_add("ok", "1.0", "end")
            self.errores_text.tag_config("ok", foreground=SUCCESS_COLOR)
            self.nb.tab(1, text="  Errores (0)  ")
        self.errores_text.config(state="disabled")

        # Status
        self.status_lbl.config(
            text=f"✔  {len(tokens)} tokens encontrados   "
                 f"{'⚠  ' + str(len(errores)) + ' error(es)' if errores else ''}",
            fg=SUCCESS_COLOR if not errores else WARNING_COLOR
        )
        self.nb.select(0)

